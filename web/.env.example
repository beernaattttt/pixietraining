# Copy to .env.local for local dev. In production, set these in
# Vercel -> Project -> Settings -> Environment Variables. NEVER commit
# an actual .env.local or .env file with real values.

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                  # generate: openssl rand -base64 32

# Discord OAuth app (discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Firebase Admin (Firebase Console -> Project Settings -> Service Accounts
# -> Generate new private key -> use the three fields from that JSON)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=             # keep the \n sequences literal, wrap in quotes

# Shared secret ONLY your Roblox game servers know. Generate a long
# random value, put it here AND in Roblox (ServerScriptService, never
# a LocalScript). Rotate by changing both sides.
# generate: openssl rand -hex 32
ROBLOX_SERVER_KEY=
